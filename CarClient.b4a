Sub Globals
	'These global variables will be redeclared each time the activity is created.
	Private Backward As Button
	Private Forward As Button
	Private TurnLeft As Button
	Private TurnRight As Button
	Private Shutdown As Button
	Private Stop As Button
	Private Speed As EditText
	Private ResultsLabel As Label
	'Private CarIP = As String ("http://192.168.11.106:8090/")
	'Private CarIP = As String ("http://192.168.1.105:8090/") ' need to add firewall rule to let it get to R.PI
	Private baseURL As EditText
	Private On As Button
	Private Off As Button
	
	Private Status As Button
	Private StartRecording As Button
	Private StopRecording As Button
	Private CancelRecording As Button
	Private RefreshRecording As Button
	Private Recordings As ListView
	Private Repitition As EditText
	Private Right As Button
	Private Left As Button
	Private EdtTTime As EditText
	Private BtnRemote As Button
	Private ChkRemoteDebug As CheckBox
	Private pnlRemoteDebug As Panel
	Private btnRemoteBack As Button
	Private lvRemoteDebug As ListView
	Private lblRemoteTitle As Label
	Private btnClearDebug As Button
	Private RemoteConnected As Boolean
	Private RemoteCurrentSpeed As Int
	Private DebugLogItems As List
	Private TouchUiViews As List
	Private RemoteMotionListener As Object
	Private RemoteStickState As String
	Private pnlRemoteInput As Panel
End Sub

Sub Activity_Create(FirstTime As Boolean)
	Activity.LoadLayout("carLayout")
	DebugLogItems.Initialize
	TouchUiViews.Initialize
	RemoteStickState = ""
	SetupRemoteUi
	PositionRemoteButton
	AttachRemoteMotionListener
	RemoteCurrentSpeed = ParseSpeedFromUi
	Log("Welcome to Car-PI")
End Sub

Sub Activity_Resume

End Sub

Sub Activity_Pause (UserClosed As Boolean)

End Sub

Private Sub SetupRemoteUi
	RegisterTouchUiViews

	BtnRemote.Initialize("BtnRemote")
	BtnRemote.Text = "REMOTE " & Chr(0x1F3AE)
	BtnRemote.TextSize = 13
	BtnRemote.Color = Colors.RGB(120, 120, 120)
	BtnRemote.TextColor = Colors.White
	Activity.AddView(BtnRemote, 5dip, 5dip, 115dip, 42dip)
	Dim joBtn As JavaObject = BtnRemote
	joBtn.RunMethod("setFocusable", Array(False))
	joBtn.RunMethod("setFocusableInTouchMode", Array(False))

	pnlRemoteDebug.Initialize("")
	pnlRemoteDebug.Color = Colors.Black
	pnlRemoteDebug.Visible = False
	Activity.AddView(pnlRemoteDebug, 0, 0, 100%x, 100%y)

	lblRemoteTitle.Initialize("")
	lblRemoteTitle.Text = "Remote Debug View"
	lblRemoteTitle.TextColor = Colors.White
	lblRemoteTitle.TextSize = 20
	lblRemoteTitle.Gravity = Gravity.CENTER_VERTICAL
	pnlRemoteDebug.AddView(lblRemoteTitle, 10dip, 10dip, 70%x, 40dip)

	btnRemoteBack.Initialize("btnRemoteBack")
	btnRemoteBack.Text = "Close"
	btnRemoteBack.Color = Colors.RGB(180, 40, 40)
	btnRemoteBack.TextColor = Colors.White
	pnlRemoteDebug.AddView(btnRemoteBack, 78%x, 10dip, 20%x, 40dip)
	Dim joBack As JavaObject = btnRemoteBack
	joBack.RunMethod("setFocusable", Array(False))
	joBack.RunMethod("setFocusableInTouchMode", Array(False))

	btnClearDebug.Initialize("btnClearDebug")
	btnClearDebug.Text = "Clear"
	btnClearDebug.Color = Colors.RGB(60, 60, 60)
	btnClearDebug.TextColor = Colors.White
	pnlRemoteDebug.AddView(btnClearDebug, 10dip, 10dip, 16%x, 40dip)
	Dim joClear As JavaObject = btnClearDebug
	joClear.RunMethod("setFocusable", Array(False))
	joClear.RunMethod("setFocusableInTouchMode", Array(False))

	lvRemoteDebug.Initialize("lvRemoteDebug")
	pnlRemoteDebug.AddView(lvRemoteDebug, 10dip, 60dip, 96%x - 20dip, 100%y - 70dip)
	Dim joList As JavaObject = lvRemoteDebug
	joList.RunMethod("setFocusable", Array(False))
	joList.RunMethod("setFocusableInTouchMode", Array(False))

	pnlRemoteInput.Initialize("")
	pnlRemoteInput.Color = Colors.Transparent
	pnlRemoteInput.Visible = False
	pnlRemoteInput.Enabled = True
	pnlRemoteInput.SetLayout(0, 0, 1dip, 1dip)
	Activity.AddView(pnlRemoteInput, 0, 0, 1dip, 1dip)
End Sub

Private Sub PositionRemoteButton
	Dim buttonWidth As Int = 115dip
	Dim buttonHeight As Int = 42dip
	Dim buttonX As Int = (Left.Left + Right.Left + Right.Width - buttonWidth) / 2
	Dim buttonY As Int = Left.Top + ((Left.Height - buttonHeight) / 2)
	If buttonX < 5dip Then buttonX = 5dip
	If buttonY < 5dip Then buttonY = 5dip
	BtnRemote.SetLayout(buttonX, buttonY, buttonWidth, buttonHeight)
	BtnRemote.BringToFront

	Dim chkWidth As Int = buttonWidth
	Dim chkHeight As Int = 36dip
	ChkRemoteDebug.Initialize("ChkRemoteDebug")
	ChkRemoteDebug.Text = "Debug mode"
	ChkRemoteDebug.TextColor = Colors.RGB(50, 50, 50)
	ChkRemoteDebug.Checked = False
	Dim chkY As Int = buttonY - chkHeight - 4dip
	If chkY < 2dip Then chkY = buttonY + buttonHeight + 4dip
	Activity.AddView(ChkRemoteDebug, buttonX, chkY, chkWidth, chkHeight)
	ChkRemoteDebug.BringToFront
End Sub

Private Sub AttachRemoteMotionListener
	Dim jo As JavaObject
	jo = pnlRemoteInput
	RemoteMotionListener = jo.CreateEvent("android.view.View$OnGenericMotionListener", "RemoteMotion", False)
	jo.RunMethod("setOnGenericMotionListener", Array(RemoteMotionListener))
	jo.RunMethod("setFocusableInTouchMode", Array(True))
	jo.RunMethod("requestFocus", Null)
End Sub

Private Sub RegisterTouchUiViews
	TouchUiViews.Clear
	TouchUiViews.Add(Backward)
	TouchUiViews.Add(Forward)
	TouchUiViews.Add(TurnLeft)
	TouchUiViews.Add(TurnRight)
	TouchUiViews.Add(Shutdown)
	TouchUiViews.Add(Stop)
	TouchUiViews.Add(Speed)
	TouchUiViews.Add(baseURL)
	TouchUiViews.Add(On)
	TouchUiViews.Add(Off)
	TouchUiViews.Add(Status)
	TouchUiViews.Add(StartRecording)
	TouchUiViews.Add(StopRecording)
	TouchUiViews.Add(CancelRecording)
	TouchUiViews.Add(RefreshRecording)
	TouchUiViews.Add(Recordings)
	TouchUiViews.Add(Repitition)
	TouchUiViews.Add(Right)
	TouchUiViews.Add(Left)
	TouchUiViews.Add(EdtTTime)
End Sub

Private Sub SetTouchUiVisible(isVisible As Boolean)
	For i = 0 To TouchUiViews.Size - 1
		Dim v As View = TouchUiViews.Get(i)
		v.Visible = isVisible
	Next
End Sub

Private Sub ParseSpeedFromUi As Int
	Dim s As String = Speed.Text
	If IsNumber(s) Then
		Return Max(0, s)
	End If
	Return 50
End Sub

Private Sub BtnRemote_Click
	If RemoteConnected Then
		DisconnectRemoteController
	Else
		ConnectRemoteController
	End If
End Sub

Private Sub IsGamepadConnected As Boolean
	Try
		Dim joDevice As JavaObject
		joDevice.InitializeStatic("android.view.InputDevice")
		Dim ids() As Int = joDevice.RunMethod("getDeviceIds", Null)
		For Each id As Int In ids
			Dim device As JavaObject = joDevice.RunMethod("getDevice", Array(id))
			If device.IsInitialized Then
				Dim sources As Int = device.RunMethod("getSources", Null)
				' SOURCE_GAMEPAD = 0x401 = 1025, SOURCE_JOYSTICK = 0x1000010 = 16777232
				If Bit.And(sources, 1025) = 1025 Or Bit.And(sources, 16777232) = 16777232 Then
					Return True
				End If
			End If
		Next
	Catch
		Log("IsGamepadConnected error: " & LastException.Message)
	End Try
	Return False
End Sub

Private Sub ConnectRemoteController
	If IsGamepadConnected = False Then
		ResultsLabel.Text = "No controller found"
		AddDebugLog("connect failed: no gamepad detected")
		Return
	End If
	RemoteCurrentSpeed = ParseSpeedFromUi
	RemoteConnected = True
	BtnRemote.Color = Colors.RGB(30, 150, 70)
	If ChkRemoteDebug.Checked Then
		BtnRemote.Visible = False
		ChkRemoteDebug.Visible = False
		SetTouchUiVisible(False)
		pnlRemoteDebug.BringToFront
		pnlRemoteDebug.Visible = True
		pnlRemoteInput.BringToFront
		Dim jo As JavaObject = pnlRemoteInput
		jo.RunMethod("requestFocus", Null)
		AddDebugLog("remote connected")
		AddDebugLog("input mode: left stick")
	Else
		pnlRemoteInput.BringToFront
		Dim jo2 As JavaObject = pnlRemoteInput
		jo2.RunMethod("requestFocus", Null)
	End If
	ResultsLabel.Text = "Remote connected"
End Sub

Private Sub DisconnectRemoteController
	RemoteConnected = False
	pnlRemoteDebug.Visible = False
	SetTouchUiVisible(True)
	BtnRemote.Visible = True
	ChkRemoteDebug.Visible = True
	BtnRemote.BringToFront
	ChkRemoteDebug.BringToFront
	BtnRemote.Color = Colors.RGB(120, 120, 120)
	ResultsLabel.Text = "Remote disconnected"
	AddDebugLog("remote disconnected")
End Sub

Private Sub btnRemoteBack_Click
	DisconnectRemoteController
End Sub

Private Sub btnClearDebug_Click
	DebugLogItems.Clear
	RefreshDebugList
End Sub

Private Sub RemoteApiCall(description As String, CommandPath As String)
	AddDebugLog(description & " -> " & CommandPath)
	restCall(CommandPath)
End Sub

Private Sub AddDebugLog(message As String)
	Dim stamped As String = DateTime.Time(DateTime.Now) & " - " & message
	DebugLogItems.InsertAt(0, stamped)
	RefreshDebugList
End Sub

Private Sub RefreshDebugList
	lvRemoteDebug.Clear
	For i = 0 To DebugLogItems.Size - 1
		lvRemoteDebug.AddSingleLine(DebugLogItems.Get(i))
	Next
End Sub

Private Sub Activity_KeyPress(KeyCode As Int) As Boolean
	If KeyCode = KeyCodes.KEYCODE_BACK And pnlRemoteDebug.Visible Then
		DisconnectRemoteController
		Return True
	End If

	If RemoteConnected = False Then Return False

	Select KeyCode
		Case KeyCodes.KEYCODE_DPAD_UP
			RemoteApiCall("forward", baseURL.Text & "drive/front/" & RemoteCurrentSpeed)
			Return True
		Case KeyCodes.KEYCODE_DPAD_DOWN
			RemoteApiCall("backward", baseURL.Text & "drive/back/" & RemoteCurrentSpeed)
			Return True
		Case KeyCodes.KEYCODE_DPAD_LEFT
			RemoteApiCall("left", baseURL.Text & "drive/left/" & RemoteCurrentSpeed)
			Return True
		Case KeyCodes.KEYCODE_DPAD_RIGHT
			RemoteApiCall("right", baseURL.Text & "drive/right/" & RemoteCurrentSpeed)
			Return True
		Case 96 'KEYCODE_BUTTON_A
			RemoteApiCall("stop", baseURL.Text & "drive/stop")
			Return True
		Case 99 'KEYCODE_BUTTON_X
			RemoteApiCall("shift left", baseURL.Text & "drive/left/" & RemoteCurrentSpeed)
			Return True
		Case 97 'KEYCODE_BUTTON_B
			RemoteApiCall("shift right", baseURL.Text & "drive/right/" & RemoteCurrentSpeed)
			Return True
		Case 102 'KEYCODE_BUTTON_L1
			RemoteCurrentSpeed = Max(0, RemoteCurrentSpeed - 5)
			AddDebugLog("speed down to " & RemoteCurrentSpeed)
			Return True
		Case 103 'KEYCODE_BUTTON_R1
			RemoteCurrentSpeed = Min(100, RemoteCurrentSpeed + 5)
			AddDebugLog("speed up to " & RemoteCurrentSpeed)
			Return True
		Case Else
			Return False
	End Select
End Sub

