' Recording operation
Private Sub StartRecording_Click
	Log ("Start recording")	
	Dim input As B4XInputTemplate
	Dim dialog As B4XDialog	
	dialog.Initialize(Activity)
	input.Initialize
	input.lblTitle.Text = "Enter Recording Name:"	
	Wait For (dialog.ShowTemplate(input, "OK", "", "CANCEL")) Complete (Result As Int)
	If Result = xui.DialogResponse_Positive Then
		Log (input.Text)
		Dim CommandPath As String
		CommandPath = baseURL.Text & "recording/start/" & input.Text
		restCall(CommandPath)		
	End If	
End Sub

Private Sub RemoteMotion_Event (MethodName As String, Args() As Object) As Object
	If RemoteConnected = False Then Return False

	Dim motion As JavaObject = Args(1)
	Dim axisX As Float = motion.RunMethod("getAxisValue", Array(0))
	Dim axisY As Float = motion.RunMethod("getAxisValue", Array(1))
	Dim deadZone As Float = 0.20
	Dim newState As String = "center"

	If axisY < -deadZone Then
		newState = "forward"
	Else If axisY > deadZone Then
		newState = "backward"
	Else If axisX < -deadZone Then
		newState = "left"
	Else If axisX > deadZone Then
		newState = "right"
	End If

	If newState <> RemoteStickState Then
		RemoteStickState = newState
		If newState = "forward" Then
			RemoteApiCall("stick forward", baseURL.Text & "drive/front/" & RemoteCurrentSpeed)
		Else If newState = "backward" Then
			RemoteApiCall("stick backward", baseURL.Text & "drive/back/" & RemoteCurrentSpeed)
		Else If newState = "left" Then
			RemoteApiCall("stick turn left", baseURL.Text & "drive/turnLeft/" & RemoteCurrentSpeed & "/" & EdtTTime.Text)
			Else If newState = "right" Then
			RemoteApiCall("stick turn right", baseURL.Text & "drive/turnRight/" & RemoteCurrentSpeed & "/" & EdtTTime.Text)
		Else
			RemoteApiCall("stick center - stop", baseURL.Text & "drive/stop")
		End If
	End If

	Return False
End Sub

